{
  "dependencies": {
    "@better-auth/api-key": "^1.6.20",
    "@better-auth/drizzle-adapter": "^1.6.20",
    "@hono/node-server": "^2.0.5",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.11.4",
    "better-auth": "^1.6.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "ultracite": "7.8.3",
    "vitest": "^4.1.9"
  },
  "name": "my-app",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "db:auth:generate": "pnpm dlx auth@latest generate --config src/auth.ts --output src/db/better-auth-schema.ts --yes",
    "db:auth:migrate": "pnpm dlx auth@latest migrate --config src/auth.ts --yes",
    "db:push": "drizzle-kit push",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:ps": "docker compose ps",
    "infra:build": "docker compose build",
    "infra:restart": "docker compose restart",
    "test": "vitest run",
    "test:e2e": "vitest run test/auth.e2e.test.ts test/posts.e2e.test.ts",
    "prepare": "husky"
  },
  "type": "module"
}
