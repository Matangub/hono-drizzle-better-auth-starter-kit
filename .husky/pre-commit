#!/bin/sh
# Quality checks: ultracite, typecheck, fallow, tests

# Check if there are any staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to check"
  exit 0
fi

# Run quality checks
echo "Running quality checks..."
pnpm run quality
QUALITY_EXIT_CODE=$?

# Re-stage files that were already staged (in case formatter made changes)
echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add -- "$file"
  fi
done

exit $QUALITY_EXIT_CODE

if [ $FORMAT_EXIT_CODE -ne 0 ]; then
  echo "Ultracite found issues that could not be auto-fixed."
  exit $FORMAT_EXIT_CODE
fi

echo "Running typecheck..."
pnpm run typecheck

if [ $? -ne 0 ]; then
  echo "Typecheck failed."
  exit 1
fi

echo "✨ Files formatted by Ultracite"
# ultracite end
